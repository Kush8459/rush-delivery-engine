# Copy to .env and edit as needed. Env vars are prefixed DE_ and use _ for dots.
# Example: DE_POSTGRES_HOST maps to postgres.host in config.yaml.

DE_ENV=local
DE_POSTGRES_HOST=localhost
DE_POSTGRES_PORT=5433
DE_POSTGRES_NAME=delivery_engine
DE_POSTGRES_USER=postgres
DE_POSTGRES_PASSWORD=postgres
DE_REDIS_ADDR=localhost:6379
DE_KAFKA_BROKERS=localhost:9092
